# Auth0 Configuration
# Create an application at https://auth0.com/ and copy these values from its settings.
# The Auth0 SDK for Next.js reads these automatically.
APP_BASE_URL='http://localhost:3000'
AUTH0_DOMAIN='your-tenant.auth0.com'
AUTH0_CLIENT_ID='your-auth0-client-id'
AUTH0_CLIENT_SECRET='your-auth0-client-secret'
AUTH0_SECRET='generate-with-openssl-rand-hex-32'

# Meta / Facebook Configuration
# Get these values from the Meta Developer Dashboard: https://developers.facebook.com/apps/
FB_APP_ID='your-facebook-app-id'
FB_APP_SECRET='your-facebook-app-secret'
FB_GRAPH_API_VERSION='v22.0'
FB_REG_PIN='your-registration-pin'
FB_VERIFY_TOKEN='your-webhook-verify-token'

# Ably Configuration
# Get this from your Ably dashboard: https://ably.com/accounts
ABLY_KEY='your-ably-api-key'

# Contact Information
TP_CONTACT_EMAIL='your-contact-email@example.com'

# Database (auto-configured when using Vercel + Neon integration)
# POSTGRES_URL='postgres://...'

# Note: Copy this file to .env.local and replace the placeholder values with your actual secrets.
# Never commit .env.local to version control.
